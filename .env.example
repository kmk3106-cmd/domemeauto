# ===== 도매매 오토 비밀정보 템플릿 =====
# 이 파일을 .env 로 복사한 뒤 실제 값으로 채우세요. (.env 는 git 커밋 금지)

# 1~6번 사업자 아이디 (쉼표 구분, 순서 = 사업자 번호)
DOMEME_ACCOUNTS=id1,id2,id3,id4,id5,id6
# 도매매 공통 비밀번호 (대소문자 구분)
DOMEME_PASSWORD=

# 네이버 DataLab (쇼핑인사이트) API
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# OpenAI API (STEP3 / STEP4 / STEP6 공용)
OPENAI_API_KEY=

# 네이버 클라우드 Object Storage (STEP5 / STEP5-1 공용)
NCLOUD_ACCESS_KEY=
NCLOUD_SECRET_KEY=

# ===== 통합 포털 (MVP: 출고중지 / 미응대 문의) =====
# 사업자 rank 1~6 별 쿠팡 마켓플레이스 OpenAPI (WING). 없으면 비워두면 '미연동' 표시.
COUPANG_1_VENDOR_ID=
COUPANG_1_ACCESS_KEY=
COUPANG_1_SECRET_KEY=
COUPANG_2_VENDOR_ID=
COUPANG_2_ACCESS_KEY=
COUPANG_2_SECRET_KEY=
COUPANG_3_VENDOR_ID=
COUPANG_3_ACCESS_KEY=
COUPANG_3_SECRET_KEY=
COUPANG_4_VENDOR_ID=
COUPANG_4_ACCESS_KEY=
COUPANG_4_SECRET_KEY=
COUPANG_5_VENDOR_ID=
COUPANG_5_ACCESS_KEY=
COUPANG_5_SECRET_KEY=
COUPANG_6_VENDOR_ID=
COUPANG_6_ACCESS_KEY=
COUPANG_6_SECRET_KEY=
